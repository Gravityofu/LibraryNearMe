// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 도서관 (여러 도서관이 한 시스템을 함께 씁니다)
model Library {
  id           Int      @id @default(autoincrement())
  name         String
  logoUrl      String?
  primaryColor String   @default("#2563eb")
  domain       String?  @unique   // 이 도서관 홈페이지 도메인 (나중에 도메인별 서비스용)
  createdAt    DateTime @default(now())

  users        User[]             // 이 도서관에 속한 사용자들 (연결고리)
  materials    Material[]   // ← 추가
  copies       Copy[]       // ← 추가
}

// 사용자 (회원 / 관리자 / 슈퍼계정 모두 여기에 담습니다)
model User {
  id            Int        @id @default(autoincrement())

  libraryId     Int                          // 어느 도서관 소속인지
  library       Library    @relation(fields: [libraryId], references: [id])

  createdMaterials Material[]   // 이 사서가 등록한 자료들
  createdCopies    Copy[]       // 이 사서가 등록한 실물들

  loginId       String?                      // 아이디(도서관 내 고유). 이전 회원은 나중에 설정 → 비어도 됨
  passwordHash  String?                      // 암호화된 비밀번호. 소셜·이전 회원 대비 비어도 됨

  name          String                       // 이름 (필수)
  phone         String?                      // 휴대폰 번호. 중복 허용 (가입 화면에서 입력받음)
  phoneVerified Boolean    @default(false)    // 번호 인증 여부 (나중 문자 인증용)
  email         String?                      // 이메일 (선택)
  birthDate     DateTime?                     // 생년월일 (선택)
  address       String?                       // 주소 (선택)
  postalCode    String?                       // 우편번호 (선택)

  memberNo      String?                       // 회원증 번호(사람이 읽는). 기존 "U012345" 그대로 or 신규 발급
  cardToken     String     @unique            // QR 보안 코드(기계용). 무작위 고유값

  role          Role       @default(MEMBER)   // 역할
  status        UserStatus @default(ACTIVE)   // 계정 상태

  provider      String?                       // 소셜 로그인 경로 (나중용, 지금 비움)
  providerId    String?                       // 소셜 계정 식별값 (나중용, 지금 비움)

  createdAt     DateTime   @default(now())

  @@unique([libraryId, loginId])              // 같은 도서관 안에서 아이디 중복 금지
  @@unique([libraryId, memberNo])             // 같은 도서관 안에서 회원증번호 중복 금지
}

// 역할: 아래 셋 중 하나만 가질 수 있음
enum Role {
  SUPER    // 슈퍼계정 (전체 관리)
  ADMIN    // 도서관 관리자
  MEMBER   // 일반 이용자
}

// 계정 상태
enum UserStatus {
  ACTIVE      // 활성
  PENDING     // 대기 (이전됐지만 아직 활성화 안 함 등)
  SUSPENDED   // 정지 / 탈퇴
}

// 자료 정보 (서지 레코드)
model Material {
  id          Int      @id @default(autoincrement())

  libraryId   Int
  library     Library  @relation(fields: [libraryId], references: [id])

  type        String   // 자료 종류 코드 (book, dvd, thesis, ...)
  title       String   // 서명 — MARC 245 ▼a
  creator     String?  // 저자 — MARC 100(있으면) / 없으면 245 ▼d
  publisher   String?  // 발행처 — MARC 260 ▼b
  pubYear     String?  // 발행년 — MARC 260 ▼c
  isbn        String?  // ISBN — MARC 020 ▼a
  classNumber String?  // 분류기호 — MARC 056 (책·DVD 자동추출, 비도서는 선택 입력)
  format      String?  // 형태(크기·파일형식) — MARC 300
  subject     String?  // 주제어 — MARC 653
  language    String?  // 언어 — MARC 041
  summary     String?  // 요약/설명 — MARC 500 ▼a
  coverUrl    String?  // 표지 이미지 주소
  onlineUrl   String?  // 온라인 접근 주소

  marc        Json?    // 구조화된 MARC(태그 목록) — 책·DVD 서지 원본(편집본)
  marcRaw     String?  // KOLIS-NET 원본 문자열 그대로 보관
  extra       Json?    // 종류별 특수 정보

  createdById Int?     // 이 자료를 등록한 사서
  createdBy   User?    @relation(fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  copies      Copy[]

  @@index([libraryId])
}

// 실물 개별 자료 (소장 부수) — 실물이 있는 모든 종류에 등록
model Copy {
  id             Int        @id @default(autoincrement())

  libraryId      Int
  library        Library    @relation(fields: [libraryId], references: [id])
  materialId     Int
  material       Material   @relation(fields: [materialId], references: [id])

  registrationNo String     // 등록번호(고유번호) — 도서관 내 고유
  callNumber     String?    // 청구기호 (이용자가 자료 찾는 번호, 시리즈·COPY 번호 포함)
  authorCode     String?    // 저자기호 (MARC 090 ▼b)
  volume         String?    // 권/호 (예: v.1, 시리즈물일 때 몇 권째인지)
  copyNumber     String?    // 복본 (예: c.1, 같은 자료 중 몇 번째 것인지)
  specialCode    String?    // 별치기호
  shelfNo        String?    // 서가번호
  location       String?    // 소장처 (예: 2층 문학)
  memo           String?    // 메모
  status         CopyStatus @default(AVAILABLE)

  createdById    Int?       // 이 실물을 등록한 사서
  createdBy      User?      @relation(fields: [createdById], references: [id])

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([libraryId, registrationNo])
  @@index([materialId])
}

// 부수 상태 (대출/제적 기능 만들 때 더 다듬을 예정)
enum CopyStatus {
  AVAILABLE   // 비치(대출 가능)
  ON_LOAN     // 대출중
  RESERVED    // 예약 대기
  REPAIR      // 보수중
  LOST        // 분실
  WITHDRAWN   // 제적
}